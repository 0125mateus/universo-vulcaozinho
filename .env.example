# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost
DJANGO_SECURE_COOKIES=False

# PostgreSQL (docker compose produção)
POSTGRES_DB=vulcaozinho
POSTGRES_USER=vulcaozinho
POSTGRES_PASSWORD=change-me-in-production

# Banco SQLite (apenas dev local ou docker-compose.dev.yml)
# DATABASE_PATH=

# Telão — API pública read-only
TELAO_API_KEY=vulcaozinho-telao-dev

# Dev: login automático como superuser (True/False)
DEV_SKIP_LOGIN=False

# Assistente IA (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Docker: rodar seeds na primeira subida (1/0)
RUN_SEED=1

# WebSocket multi-worker (Docker/produção). Dev local: omita para usar InMemory.
# REDIS_URL=redis://127.0.0.1:6379/0

# Porta HTTP exposta pelo nginx
HTTP_PORT=80
